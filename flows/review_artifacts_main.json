{
  "description": "Generate the main review artifacts for the current story without running disposition, fixing, task-up, or closeout steps.",
  "steps": [
    {
      "type": "validateReviewTarget",
      "label": "Validate Bound Review Target",
      "targetFrom": "target"
    },
    {
      "type": "reingest",
      "label": "Re-embed the bound review target",
      "target": "working"
    },
    {
      "type": "command",
      "label": "Run Review Evidence Gate",
      "agentType": "review_agent",
      "identifier": "reviewer_evidence",
      "commandName": "target_review_evidence_gate"
    },
    {
      "type": "command",
      "label": "Run Code Review Findings",
      "agentType": "review_agent",
      "identifier": "reviewer_findings",
      "commandName": "target_code_review_findings"
    },
    {
      "type": "llm",
      "label": "Review Visual Design Conformance",
      "agentType": "review_agent_lite",
      "identifier": "reviewer_visual",
      "markdownFile": "review_visual_design_conformance.md"
    },
    {
      "type": "command",
      "label": "Run Findings Saturation",
      "agentType": "review_agent_lite",
      "identifier": "reviewer_saturation",
      "commandName": "target_review_findings_saturation"
    },
    {
      "type": "command",
      "label": "Run Blind-Spot Challenge",
      "agentType": "review_agent_lite",
      "identifier": "reviewer_blindspot",
      "commandName": "target_review_blind_spot_challenge"
    }
  ]
}
