{
  "description": "Run an isolated generic diagnostic review batch without final story settlement ownership.",
  "steps": [
    {
      "type": "initializeReviewCycle",
      "label": "Initialize Isolated Diagnostic Review",
      "mode": "diagnostic",
      "outputKey": "diagnostic_review"
    },
    {
      "type": "subflowWave",
      "label": "Run Diagnostic Generic Review Batch",
      "failureMode": "best_effort",
      "groups": [
        {
          "kind": "singleton",
          "id": "diagnostic_review_batch",
          "flowName": "review_batch",
          "bindings": {
            "inputValues": {
              "review_groups": [
                {
                  "kind": "matrix",
                  "id": "target_reviews",
                  "itemsFrom": "review_batch_targets.targets",
                  "itemName": "target",
                  "flowNames": ["codex_review", "open_code_review"],
                  "bindings": {
                    "workingFolderFrom": "target.repo_root",
                    "input": {
                      "target": "target",
                      "review_wave": "review_batch_targets"
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
