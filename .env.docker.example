# Host path to expose to the server container for ingest.
# macOS example:
# CODEINFO_HOST_INGEST_DIR=/Users/your-username/Documents
# Windows example (note the drive letter and backslashes or forward slashes):
# CODEINFO_HOST_INGEST_DIR=C:\\Users\\your-username\\Documents
# CODEINFO_HOST_INGEST_DIR=C:/Users/your-username/Documents
CODEINFO_HOST_INGEST_DIR=/Users/your-username/Documents
