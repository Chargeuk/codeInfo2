CODEINFO_SERVER_PORT=5010
# Adjust CORS origins if needed; use .env.local for private overrides
CODEINFO_LMSTUDIO_BASE_URL=http://host.docker.internal:1234
CODEINFO_CHAT_DEFAULT_PROVIDER=codex
CODEINFO_CHROMA_URL=http://host.docker.internal:8300
CODEINFO_CHAT_MCP_PORT=5011 # Codex-only MCP JSON-RPC port
# Dedicated web-tools MCP JSON-RPC port
CODEINFO_WEB_MCP_PORT=5013
CODEINFO_INGEST_COLLECTION=ingest_vectors
CODEINFO_INGEST_ROOTS_COLLECTION=ingest_roots
CODEINFO_INGEST_FLUSH_EVERY=20
# Minimum file size in bytes before large .md/.mdx/.txt files use the prose chunking path
CODEINFO_INGEST_LARGE_TEXT_THRESHOLD_BYTES=65536
# OpenAI batching can mix multiple chunk inputs per request; values above supported limits are clamped
CODEINFO_INGEST_OPENAI_MAX_BATCH_SIZE=20
# OpenAI embedding requests in flight at once; values above the supported limit are clamped
CODEINFO_INGEST_OPENAI_MAX_INFLIGHT=10
# LM Studio still embeds one input per request even if configured higher; the effective batch size clamps to 1
CODEINFO_INGEST_LMSTUDIO_MAX_BATCH_SIZE=1
# LM Studio embedding requests in flight at once; values above the supported limit are clamped
CODEINFO_INGEST_LMSTUDIO_MAX_INFLIGHT=4
# Extra cap for waiting embedding work: -1 means no extra cap beyond derived dispatcher bounds, 0 disables waiting, positive values cap queue depth
CODEINFO_INGEST_MAX_QUEUE_SIZE=-1
CODEINFO_OPENAI_INGEST_MAX_RETRIES=7
CODEINFO_MONGO_URI=mongodb://host.docker.internal:27517/db?directConnection=true
CODEINFO_INGEST_EXCLUDE=node_modules,.git,dist,build,coverage,logs,vendor,*.log,*.min.js,package-lock.json,yarn.lock,pnpm-lock.yaml
CODEINFO_INGEST_INCLUDE=ts,tsx,js,jsx,mjs,cjs,json,jsonc,md,mdx,txt,py,java,kt,kts,go,rs,rb,php,cs,cpp,cc,c,h,hpp,swift,scala,clj,cljs,edn,sh,bash,zsh,ps1,yaml,yml,toml,ini,cfg,env,sql,tf,tfvars,dart,vue,html,css,scss,sass,less,xml,hs,lhs,r,erl,ex,exs,elm,tfbackend,makefile,dockerfile,Terrafile,dockerignore,.dockerignore,gitattributes,gitignore,example,template,tmpl,drawio,hcl,mod,sum,cucumber,feature,crt,pem,key,npmrc,yarnrc,pnpmfile,gradle,gradle.kts,properties,prettierignore,stylelintrc,eslintrc,babelrc,jshintrc,htaccess,htpasswd,prettierrc,local
CODEINFO_LOG_LEVEL=info
CODEINFO_LOG_BUFFER_MAX=5000
CODEINFO_LOG_MAX_CLIENT_BYTES=32768
CODEINFO_LOG_FILE_ROTATE=true

CODEINFO_LOG_LEVEL=debug

CODEINFO_LOG_FILE_PATH=../logs/server.log
CODEINFO_CODEX_HOME=../codex
CODEINFO_COPILOT_HOME=../copilot
CODEINFO_COPILOT_SEND_AND_WAIT_TIMEOUT_SEC=7200
# CODEINFO_COPILOT_CLI_PATH=/usr/local/bin/copilot
CODEINFO_AGENT_HOME=../codeinfo_agents
CODEINFO_CODEX_AGENT_HOME=../codex_agents
CODEINFO_AGENT_PROVIDER_FALLBACK_ORDER=codex,copilot
CODEINFO_AGENTS_MCP_PORT=5012
CODEINFO_CODEX_WORKDIR=${HOME}/Documents/dev
Codex_sandbox_mode=danger-full-access
Codex_approval_policy=never
Codex_reasoning_effort=high
Codex_network_access_enabled=true
Codex_web_search_enabled=true
Codex_model_list=gpt-5.6-sol,gpt-5.6-terra,gpt-5.6-luna,gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3-codex,gpt-5.3-codex-spark
# Retrieval cutoff defaults (distance <= cutoff kept; lower is better)
# CODEINFO_RETRIEVAL_DISTANCE_CUTOFF=1.4
# CODEINFO_RETRIEVAL_CUTOFF_DISABLED=false
# CODEINFO_RETRIEVAL_FALLBACK_CHUNKS=2

# Tool payload caps (characters)
# CODEINFO_TOOL_MAX_CHARS=40000
# CODEINFO_TOOL_CHUNK_MAX_CHARS=5000

# Host path where ingest data is mounted; used to rewrite /data paths for tool responses
CODEINFO_HOST_INGEST_DIR=${CODEINFO_CODEX_WORKDIR}
