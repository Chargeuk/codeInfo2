CODEINFO_SERVER_PORT=5010
CODEINFO_CHAT_MCP_PORT=5011
CODEINFO_AGENTS_MCP_PORT=5012
# Adjust CORS origins if needed; use .env.local for private overrides
CODEINFO_LMSTUDIO_BASE_URL=http://host.docker.internal:1234
CODEINFO_CHAT_DEFAULT_PROVIDER=codex
CODEINFO_CHAT_DEFAULT_MODEL=gpt-5.3-codex
CODEINFO_CHROMA_URL=http://chroma-e2e:8000
CODEINFO_INGEST_COLLECTION=ingest_vectors_e2e
CODEINFO_INGEST_ROOTS_COLLECTION=ingest_roots_e2e
CODEINFO_MONGO_URI=mongodb://host.docker.internal:27517/db?directConnection=true
CODEINFO_INGEST_EXCLUDE=node_modules,.git,dist,build,coverage,logs,vendor,*.log,*.min.js,package-lock.json,yarn.lock,pnpm-lock.yaml
CODEINFO_INGEST_INCLUDE=ts,tsx,js,jsx,mjs,cjs,json,jsonc,md,mdx,txt,py,java,kt,kts,go,rs,rb,php,cs,cpp,cc,c,h,hpp,swift,scala,clj,cljs,edn,sh,bash,zsh,ps1,yaml,yml,toml,ini,cfg,env,sql
CODEINFO_LOG_LEVEL=info
CODEINFO_LOG_BUFFER_MAX=5000
CODEINFO_LOG_MAX_CLIENT_BYTES=32768
CODEINFO_LOG_FILE_PATH=/app/logs/server-e2e.log
CODEINFO_LOG_FILE_ROTATE=true
