{
  "description": "Exit the complete flow successfully when best-effort work is exhausted",
  "steps": [
    {
      "type": "startLoop",
      "label": "Outer loop",
      "steps": [
        {
          "type": "break",
          "label": "Best-effort exit gate",
          "agentType": "loop_control_agent",
          "identifier": "exit",
          "question": "Exit complete flow successfully?",
          "breakOn": "yes",
          "exitFlow": true
        },
        {
          "type": "llm",
          "label": "Must not run",
          "agentType": "coding_agent",
          "identifier": "after-exit",
          "messages": [
            {
              "role": "user",
              "content": [
                "This step must not execute after a best-effort exit."
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "llm",
      "label": "Also must not run",
      "agentType": "coding_agent",
      "identifier": "after-loop",
      "messages": [
        {
          "role": "user",
          "content": [
            "This top-level step must not execute after a best-effort exit."
          ]
        }
      ]
    }
  ]
}
